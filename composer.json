{
    "name": "offload-project/laravel-google-pubsub",
    "description": "Google Cloud Pub/Sub for Laravel with full feature support",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/offload-project/laravel-google-pubsub",
    "keywords": [
        "laravel",
        "queue",
        "pubsub",
        "google",
        "cloud",
        "gcp"
    ],
    "authors": [
        {
            "name": "Offload Project"
        }
    ],
    "require": {
        "php": "^8.3",
        "google/cloud-pubsub": "^2.16",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "opis/json-schema": "^2.6"
    },
    "require-dev": {
        "larastan/larastan": "^3.8.1",
        "laravel/pint": "^1.26.0",
        "orchestra/testbench": "^9.15|^10.8|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "OffloadProject\\GooglePubSub\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OffloadProject\\GooglePubSub\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OffloadProject\\GooglePubSub\\PubSubServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "test-coverage": "pest --coverage",
        "analyse": "phpstan analyse --memory-limit=-1",
        "analyse-baseline": "phpstan analyse --memory-limit=-1 --generate-baseline",
        "pint": "vendor/bin/pint"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
